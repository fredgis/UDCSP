{
  "$schema": "https://schemas.udcsp.example/verified-id/credential-contract.schema.json",
  "id": "udcsp-residency-credential",
  "type": [
    "VerifiableCredential",
    "UdcspResidencyCredential"
  ],
  "name": "UDCSP Cross-Border Residency Credential",
  "version": "1.0.0",
  "issuer": {
    "authority": "UDCSP Verified ID Issuer",
    "didMethods": [
      "ion",
      "web"
    ]
  },
  "claimFormat": "vc+sd-jwt",
  "credentialSubject": {
    "subjectId": {
      "type": "string",
      "description": "Pseudonymous subject identifier from the sovereign identity tenant."
    },
    "country": {
      "type": "string",
      "enum": [
        "DK",
        "SE",
        "NO"
      ],
      "description": "Country asserting residency."
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "residencyType": {
      "type": "string",
      "enum": [
        "permanent",
        "temporary",
        "cross-border-worker",
        "student",
        "protected"
      ]
    }
  },
  "required": [
    "subjectId",
    "country",
    "issuedAt",
    "validUntil",
    "residencyType"
  ],
  "selectiveDisclosure": [
    "country",
    "residencyType",
    "validUntil"
  ],
  "eidas2": {
    "assuranceLevel": "high",
    "purpose": "cross-border-residency-assertion"
  }
}
