{
  "$schema": "https://schemas.udcsp.example/verified-id/presentation-policy.schema.json",
  "id": "udcsp-residency-credential-policy",
  "name": "Verify UDCSP Cross-Border Residency",
  "version": "1.0.0",
  "purpose": "Confirm the holder has a current residency assertion for cross-border eligibility routing.",
  "inputDescriptors": [
    {
      "id": "udcsp-residency-credential",
      "schema": "udcsp-residency-credential",
      "constraints": {
        "fields": [
          {
            "path": [
              "$.credentialSubject.subjectId"
            ],
            "required": true
          },
          {
            "path": [
              "$.credentialSubject.country"
            ],
            "filter": {
              "type": "string",
              "pattern": "^(DK|SE|NO)$"
            },
            "required": true
          },
          {
            "path": [
              "$.credentialSubject.validUntil"
            ],
            "predicate": "isFutureDate",
            "required": true
          },
          {
            "path": [
              "$.credentialSubject.residencyType"
            ],
            "required": true
          }
        ]
      }
    }
  ],
  "trustedIssuers": [
    "did:ion:udcsp-federation-hub",
    "did:web:identity.udcsp.example"
  ],
  "openid4vp": {
    "responseType": "vp_token",
    "clientIdScheme": "redirect_uri",
    "limitDisclosure": "required"
  }
}
