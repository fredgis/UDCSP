{
  "name": "@udcsp/voice-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "UDCSP voice channel orchestrator — bridges ACS Call Automation to GPT-4o Realtime, exposes Foundry topic-router as a function tool, transfers to D365 voice workstream on escalation.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/communication-call-automation": "^1.4.0",
    "@azure/communication-common": "^2.3.1",
    "@azure/communication-identity": "^1.3.1",
    "@azure/identity": "^4.5.0",
    "@azure/monitor-opentelemetry": "^1.17.0",
    "applicationinsights": "^3.4.0",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
