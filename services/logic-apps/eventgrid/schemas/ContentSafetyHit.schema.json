{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContentSafetyHit",
  "type": "object",
  "required": [
    "id",
    "eventType",
    "subject",
    "eventTime",
    "data"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "eventType": {
      "const": "ContentSafetyHit"
    },
    "subject": {
      "type": "string"
    },
    "eventTime": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "properties": {
        "traceparent": {
          "type": "string"
        },
        "country": {
          "enum": [
            "dk",
            "se",
            "no"
          ]
        },
        "purviewLineage": {
          "type": "boolean"
        }
      }
    }
  }
}
