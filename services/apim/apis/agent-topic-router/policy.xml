<policies>
  <inbound>
    <base />
    <cors allow-credentials="false">
      <allowed-origins>
        <origin>{{portal-origin}}</origin>
        <origin>http://localhost:5173</origin>
      </allowed-origins>
      <allowed-methods><method>POST</method><method>GET</method><method>OPTIONS</method></allowed-methods>
      <allowed-headers><header>*</header></allowed-headers>
      <expose-headers><header>x-correlation-id</header></expose-headers>
    </cors>
    <set-variable name="correlationId" value="@(Guid.NewGuid().ToString())" />
    <rate-limit-by-key calls="120" renewal-period="60" counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)" />
    <set-method>POST</set-method>
    <rewrite-uri template="/openai/v1/responses" />
    <set-backend-service base-url="{{foundry-project-base}}" />
    <authentication-managed-identity resource="https://ai.azure.com" />
    <set-header name="Content-Type" exists-action="override"><value>application/json</value></set-header>
    <set-body>@{
      var src = context.Request.Body.As&lt;JObject&gt;(preserveContent: false);
      var text = (string)(src["text"] ?? "");
      var locale = (string)(src["locale"] ?? "en");
      var input = "[locale=" + locale + "] " + text;
      var payload = new JObject(
        new JProperty("model", "gpt-5.4"),
        new JProperty("agent", new JObject(new JProperty("name", "topic-router"))),
        new JProperty("input", input)
      );
      return payload.ToString();
    }</set-body>
  </inbound>
  <backend><base /></backend>
  <outbound>
    <base />
    <set-header name="x-correlation-id" exists-action="override">
      <value>@((string)context.Variables["correlationId"])</value>
    </set-header>
  </outbound>
  <on-error>
    <base />
    <set-header name="x-correlation-id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
  </on-error>
</policies>
