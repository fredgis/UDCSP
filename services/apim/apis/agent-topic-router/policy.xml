<!--
  agent-topic-router policy.
  Single APIM facade in front of the Foundry topic-router agent. Used by:
    - apps/web/src/components/ChatWidget.tsx (channel: 'web')
    - apps/voice/call-automation (channel: 'voice', via the lookup_topic_router function tool)
    - mobile + caseworker handoff surfaces

  The same backend serves all channels — that is the whole point of the
  topic-router (one brain). This policy:
    1. Validates the Entra ID token (citizen or service principal — the
       voice orchestrator authenticates as a service principal with the
       voice-orchestrator app role).
    2. Asserts the channel header is one of {web, voice, mobile-handoff,
       caseworker} and matches the body field — prevents a citizen token
       being used to spoof the voice channel actor.
    3. Rate-limits per subscription/IP with a slightly higher quota for
       voice (one call = many turns).
-->
<policies>
  <inbound>
    <base />
    <include-fragment fragment-id="correlation-id" />
    <include-fragment fragment-id="jwt-validate-entra" />

    <!-- Pull the actor from a header (set by the voice orchestrator) or fall back to web. -->
    <set-variable name="channelActor" value="@(context.Request.Headers.GetValueOrDefault(&quot;x-channel-actor&quot;, &quot;web&quot;))" />

    <choose>
      <when condition="@(new[]{&quot;web&quot;,&quot;voice&quot;,&quot;mobile-handoff&quot;,&quot;caseworker&quot;}.Contains((string)context.Variables[&quot;channelActor&quot;]) == false)">
        <return-response>
          <set-status code="400" reason="Bad Request" />
          <set-body>{ "error": "invalid x-channel-actor" }</set-body>
        </return-response>
      </when>
    </choose>

    <!-- Voice gets a higher per-key quota: a single call drives many topic-router turns. -->
    <choose>
      <when condition="@((string)context.Variables[&quot;channelActor&quot;] == &quot;voice&quot;)">
        <rate-limit-by-key calls="600" renewal-period="60" counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)" />
      </when>
      <otherwise>
        <rate-limit-by-key calls="120" renewal-period="60" counter-key="@(context.Subscription?.Key ?? context.Request.IpAddress)" />
      </otherwise>
    </choose>

    <set-header name="traceparent" exists-action="skip">
      <value>@(context.Request.Headers.GetValueOrDefault("traceparent", Guid.NewGuid().ToString()))</value>
    </set-header>
    <set-header name="x-request-tracing" exists-action="override"><value>true</value></set-header>
    <set-header name="x-channel-actor" exists-action="override"><value>@((string)context.Variables["channelActor"])</value></set-header>

    <set-backend-service base-url="{{foundry-topic-router-agent-endpoint}}" />
  </inbound>
  <backend><base /></backend>
  <outbound>
    <base />
    <set-header name="x-correlation-id" exists-action="override">
      <value>@((string)context.Variables["correlationId"])</value>
    </set-header>
  </outbound>
  <on-error>
    <base />
    <set-header name="x-correlation-id" exists-action="override">
      <value>@(context.RequestId.ToString())</value>
    </set-header>
  </on-error>
</policies>
